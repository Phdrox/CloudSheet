{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "NodeNext",
    "target": "ESNext",
    "outDir": "./dist",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": "./",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "useDefineForClassFields": false, // Importante para evitar conflitos de inicialização
    // ... outras opções padrão do NestJS
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}