{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2021",

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    "baseUrl": "./",
    "paths": {
      "src/*": ["src/*"]
    },

    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true
  }
}