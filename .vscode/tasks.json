{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Git: Add, Commit, Push",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/git-commit.ps1"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "group": {
        "kind": "none",
        "isDefault": false
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    }
  ]
}
